# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# ── Python ────────────────────────────────────────────────────────────────────
[*.py]
indent_size = 4
max_line_length = 100

# ── Frontend (TS/TSX/JS/JSX/JSON/CSS) ─────────────────────────────────────────
[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,css,scss,html}]
indent_size = 2

# ── Markdown ──────────────────────────────────────────────────────────────────
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# ── YAML ──────────────────────────────────────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2

# ── Makefile ──────────────────────────────────────────────────────────────────
[Makefile]
indent_style = tab

# ── Windows-specific (PowerShell) ─────────────────────────────────────────────
[*.{ps1,psm1,psd1}]
end_of_line = crlf
indent_size = 4
